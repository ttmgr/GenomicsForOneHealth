cff-version: 1.2.0
message: >
  If you use any pipeline from this repository in your research, please cite
  the relevant primary publication listed below. To cite the repository itself,
  use the metadata in this file.

title: "GenomicsForOneHealth: A Bioinformatics Pipeline Collection for Genomic Surveillance & One Health"
version: 1.0.0
date-released: "2026-03-01"
license: MIT
repository-code: https://github.com/ttmgr/GenomicsForOneHealth
url: https://sites.google.com/view/urban-lab/home

authors:
  - family-names: Urban
    given-names: Lara
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich
    orcid: https://orcid.org/0000-0002-5859-1657
  - family-names: Reska
    given-names: Tim
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich
  - family-names: Sauerborn
    given-names: Ela
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich
  - family-names: Ürel
    given-names: Harika
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich
  - family-names: Gygax
    given-names: Daniel
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich
  - family-names: Perlas
    given-names: Albert
    affiliation: >
      Computational Health Center, Helmholtz Munich;
      Department of Bioinformatics, University of Zurich

abstract: >
  A collection of complementary nanopore sequencing analysis pipelines for
  genomic surveillance and One Health applications, spanning environmental
  metagenomics, food safety, clinical diagnostics, veterinary virology, eDNA
  metabarcoding, and viability assessment.

keywords:
  - nanopore sequencing
  - metagenomics
  - One Health
  - antimicrobial resistance
  - food safety
  - environmental genomics
  - eDNA metabarcoding
  - avian influenza
  - bioinformatics

# ─── Primary & Pipeline Publications ────────────────────────────────────────
# Please cite the most relevant paper(s) for the pipeline(s) you used.

references:
